{
  "name": "kingdoms",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "A web-native RTS spanning medieval Bohemia to the 1918 First Czechoslovak Republic. Phaser 4 + Vite + TypeScript + bitECS.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "bitecs": "0.3.40",
    "easystarjs": "^0.4.4",
    "phaser": "beta"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "lodash": "^4.18.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.5",
    "vox-saver": "^2.0.3"
  }
}
